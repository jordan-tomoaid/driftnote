# Copy to .env.local for local dev, or set these as repo Variables/Secrets in
# GitHub (Settings → Secrets and variables → Actions) for the Pages deploy.

# GitHub Pages serves a project repo under /<repo>. The deploy workflow sets
# this to "/driftnote". Leave empty for local dev (served at the root).
NEXT_PUBLIC_BASE_PATH=

# Reddit Ads pixel (advertiser) id, from ads.reddit.com → Events Manager.
# Empty = pixel is not loaded (safe for local/preview).
NEXT_PUBLIC_REDDIT_PIXEL_ID=

# Formspree form id (the part after /f/ in your form endpoint), for waitlist
# emails. Empty = the form shows the success state without hitting a backend.
NEXT_PUBLIC_FORMSPREE_ID=
